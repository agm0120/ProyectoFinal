<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Ejercicios">

    <ScrollView
        android:id="@+id/scroll_ejercicios"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="100dp">

        <LinearLayout
            android:id="@+id/layout_contenedor_ejercicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/Grisfondo"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layout_item_andar"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <ImageView
                    android:id="@+id/iv_icono_andar"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/andar" />

                <TextView
                    android:id="@+id/tv_nombre_andar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_weight="1"
                    android:text="@string/andar"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/sw_activar_andar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:height="48dp"
                    android:checked="true"
                    android:scaleX="1.3"
                    android:scaleY="1.3"
                    android:thumbTint="@color/colores_switch"
                    android:trackTint="@color/barraswitch"
                    android:translationX="-4dp" />
            </LinearLayout>

            <View
                android:id="@+id/divisor_1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#808080" />

            <LinearLayout
                android:id="@+id/layout_item_escaleras"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <ImageView
                    android:id="@+id/iv_icono_escaleras"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/escaleras" />

                <TextView
                    android:id="@+id/tv_nombre_escaleras"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_weight="1"
                    android:text="@string/escaleras"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/sw_activar_escaleras"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:height="48dp"
                    android:checked="false"
                    android:scaleX="1.3"
                    android:scaleY="1.3"
                    android:thumbTint="@color/colores_switch"
                    android:trackTint="@color/barraswitch"
                    android:translationX="-4dp" />
            </LinearLayout>

            <View
                android:id="@+id/divisor_2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#808080" />

            <LinearLayout
                android:id="@+id/layout_item_correr"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <ImageView
                    android:id="@+id/iv_icono_correr"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/correr" />

                <TextView
                    android:id="@+id/tv_nombre_correr"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_weight="1"
                    android:text="@string/correr"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/sw_activar_correr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:height="48dp"
                    android:checked="true"
                    android:scaleX="1.3"
                    android:scaleY="1.3"
                    android:thumbTint="@color/colores_switch"
                    android:trackTint="@color/barraswitch"
                    android:translationX="-4dp" />
            </LinearLayout>

            <View
                android:id="@+id/divisor_3"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#808080" />

            <LinearLayout
                android:id="@+id/layout_item_estirar"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <ImageView
                    android:id="@+id/iv_icono_estirar"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/estirar" />

                <TextView
                    android:id="@+id/tv_nombre_estirar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_weight="1"
                    android:text="@string/estirar"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/sw_activar_estirar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:height="48dp"
                    android:checked="true"
                    android:scaleX="1.3"
                    android:scaleY="1.3"
                    android:thumbTint="@color/colores_switch"
                    android:trackTint="@color/barraswitch"
                    android:translationX="-4dp" />
            </LinearLayout>

            <View
                android:id="@+id/divisor_4"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#808080" />

            <LinearLayout
                android:id="@+id/layout_item_sentadillas"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <ImageView
                    android:id="@+id/iv_icono_sentadillas"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/sentadillas" />

                <TextView
                    android:id="@+id/tv_nombre_sentadillas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_weight="1"
                    android:text="@string/sentadillas"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/sw_activar_sentadillas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:height="48dp"
                    android:checked="true"
                    android:scaleX="1.3"
                    android:scaleY="1.3"
                    android:thumbTint="@color/colores_switch"
                    android:trackTint="@color/barraswitch"
                    android:translationX="-4dp" />
            </LinearLayout>

            <View
                android:id="@+id/divisor_final"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#808080" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>