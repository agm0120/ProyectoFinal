<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/Grisfondo"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_titulo_estirar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/verdeMenu"
        android:gravity="center"
        android:text="@string/estirar"
        android:textColor="@color/negroTexto"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layout_contenedor_estirar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_etiqueta_pregunta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:gravity="center"
            android:text="@string/pregEstirar"
            android:textColor="@color/negroTexto"
            android:textSize="17sp" />

        <LinearLayout
            android:id="@+id/layout_opciones_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp"
            android:paddingStart="40dp">

            <CheckBox
                android:id="@+id/cb_estirar_brazos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#000000"
                android:text="@string/brazos"
                android:textColor="@color/negroTexto"
                android:textSize="18sp" />

            <CheckBox
                android:id="@+id/cb_estirar_piernas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#000000"
                android:text="@string/piernas"
                android:textColor="@color/negroTexto"
                android:textSize="18sp" />

            <CheckBox
                android:id="@+id/cb_estirar_torso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#000000"
                android:text="@string/torso"
                android:textColor="@color/negroTexto"
                android:textSize="18sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_anotaciones_estirar"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="25dp"
            android:background="#FFFFFF"
            android:gravity="top|start"
            android:hint="@string/anotacion_hint"
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColorHint="#888888" />

        <Button
            android:id="@+id/btn_guardar_estirar"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/amarilloBoton"
            android:text="@string/guardar"
            android:textColor="@color/negroTexto"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>