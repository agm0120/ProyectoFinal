<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_contenedor_resultado"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/Grisfondo">

    <TextView
        android:id="@+id/tv_mensaje_exito"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="292dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="@string/msg_exito_plato"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_resultado_cuarto_1"
        android:layout_width="201dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:text="@string/resultado_c1"
        android:textColor="@color/black"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_mensaje_exito" />

    <TextView
        android:id="@+id/tv_resultado_cuarto_2"
        android:layout_width="201dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/resultado_c2"
        android:textColor="@color/black"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_resultado_cuarto_1" />

    <TextView
        android:id="@+id/tv_resultado_cuarto_3"
        android:layout_width="201dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/resultado_c3"
        android:textColor="@color/black"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_resultado_cuarto_2" />

    <TextView
        android:id="@+id/tv_resultado_cuarto_4"
        android:layout_width="201dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/resultado_c4"
        android:textColor="@color/black"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_resultado_cuarto_3" />

    <Button
        android:id="@+id/btn_guardar_plato"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginBottom="92dp"
        android:backgroundTint="@color/amarilloBoton"
        android:text="@string/btn_guardar_plato"
        android:textColor="@color/black"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_repetir_plato"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_repetir_plato"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="92dp"
        android:backgroundTint="@color/amarilloBoton"
        android:text="@string/btn_repetir_plato"
        android:textColor="@color/black"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>