<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_principal_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/Grisfondo"
    tools:context=".ActivityMain">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_cabecera"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_titulo_pantalla"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_defecto"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-light"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/v_divisor_cabecera"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#000000"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fcv_contenedor_principal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/layout_navegacion_inferior"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_cabecera" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_navegacion_inferior"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/layout_fondo_menu"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/verdeMenu"
            android:orientation="horizontal"
            android:weightSum="5"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/ib_menu_carrito"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_carrito" />

            <View
                android:id="@+id/v_divisor_menu_1"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#4A8B41"/>

            <ImageButton
                android:id="@+id/ib_menu_zapatillas"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:padding="2dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_zapatillas" />

            <View
                android:id="@+id/v_espacio_central"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/ib_menu_recetas"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_cocinero" />

            <View
                android:id="@+id/v_divisor_menu_2"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#4A8B41"/>

            <ImageButton
                android:id="@+id/ib_menu_noticias"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_noticias" />
        </LinearLayout>

        <View
            android:id="@+id/v_borde_superior_menu"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#000000"
            app:layout_constraintTop_toTopOf="@+id/layout_fondo_menu" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_principal_eatq"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_logo_eatq"
            app:backgroundTint="#FFFFFF"
            app:elevation="8dp"
            app:fabCustomSize="80dp"
            app:maxImageSize="75dp"
            app:shapeAppearanceOverlay="@null"
            app:tint="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>