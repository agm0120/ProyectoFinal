<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_noticias"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F4">

    <LinearLayout
        android:id="@+id/layout_contenedor_noticias"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/layout_noticia_principal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/fondo_redondeado"
            android:backgroundTint="#FFD9D9"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_titulo_metodo_plato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:text="@string/el_metodo"
                android:textColor="#5D4037"
                android:textSize="22sp" />

            <ImageView
                android:id="@+id/iv_imagen_metodo_plato"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="12dp"
                android:background="#E0E0E0"
                android:scaleType="centerCrop"
                android:src="@drawable/plato_saludable" />

            <Button
                android:id="@+id/btn_informacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#D7D7D7"
                android:text="@string/btn_informate"
                android:textColor="#000000"
                app:cornerRadius="20dp"
                app:strokeColor="#000000"
                app:strokeWidth="1dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_item_noticia_cardio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/fondo_redondeado"
            android:backgroundTint="#FFD9D9"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <ImageView
                android:id="@+id/iv_imagen_noticia_running"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:layout_marginEnd="12dp"
                android:background="#E0E0E0"
                android:scaleType="centerCrop"
                android:src="@drawable/practicar_deporte" />

            <LinearLayout
                android:id="@+id/layout_texto_noticia_cardio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_titulo_noticia_cardio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="@string/actividad_fisica"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_ver_noticia_cardio"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:backgroundTint="#D7D7D7"
                    android:text="@string/ver_noticia"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    app:cornerRadius="20dp"
                    app:strokeColor="#000000"
                    app:strokeWidth="1dp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_item_noticia_mental"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/fondo_redondeado"
            android:backgroundTint="#FFD9D9"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <ImageView
                android:id="@+id/iv_imagen_noticia_yoga"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:layout_marginEnd="12dp"
                android:background="#E0E0E0"
                android:scaleType="centerCrop"
                android:src="@drawable/adios_estres" />

            <LinearLayout
                android:id="@+id/layout_texto_noticia_mental"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_titulo_noticia_mental"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="@string/bienestar"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_ver_noticia_mental"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:backgroundTint="#D7D7D7"
                    android:text="@string/ver_noticia"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    app:cornerRadius="20dp"
                    app:strokeColor="#000000"
                    app:strokeWidth="1dp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_item_noticia_nutricion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/fondo_redondeado"
            android:backgroundTint="#FFD9D9"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <ImageView
                android:id="@+id/iv_imagen_noticia_nutricion"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:layout_marginEnd="12dp"
                android:background="#E0E0E0"
                android:scaleType="centerCrop"
                android:src="@drawable/img_nutricion" /> <LinearLayout
            android:id="@+id/layout_texto_noticia_nutricion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_titulo_noticia_nutricion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Nutrición Inteligente"
                android:textColor="#000000"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_ver_noticia_nutricion"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:backgroundTint="#D7D7D7"
                android:text="@string/ver_noticia"
                android:textColor="#000000"
                android:textSize="10sp"
                app:cornerRadius="20dp"
                app:strokeColor="#000000"
                app:strokeWidth="1dp" />
        </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_item_noticia_sueno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/fondo_redondeado"
            android:backgroundTint="#FFD9D9"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <ImageView
                android:id="@+id/iv_imagen_noticia_sueno"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:layout_marginEnd="12dp"
                android:background="#E0E0E0"
                android:scaleType="centerCrop"
                android:src="@drawable/img_sueno" /> <LinearLayout
            android:id="@+id/layout_texto_noticia_sueno"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_titulo_noticia_sueno"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Higiene del Sueño"
                android:textColor="#000000"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_ver_noticia_sueno"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:backgroundTint="#D7D7D7"
                android:text="@string/ver_noticia"
                android:textColor="#000000"
                android:textSize="10sp"
                app:cornerRadius="20dp"
                app:strokeColor="#000000"
                app:strokeWidth="1dp" />
        </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_item_noticia_hidratacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/fondo_redondeado"
            android:backgroundTint="#FFD9D9"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <ImageView
                android:id="@+id/iv_imagen_noticia_hidratacion"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:layout_marginEnd="12dp"
                android:background="#E0E0E0"
                android:scaleType="centerCrop"
                android:src="@drawable/img_hidratacion" /> <LinearLayout
            android:id="@+id/layout_texto_noticia_hidratacion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_titulo_noticia_hidratacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Importancia de Hidratarse"
                android:textColor="#000000"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_ver_noticia_hidratacion"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:backgroundTint="#D7D7D7"
                android:text="@string/ver_noticia"
                android:textColor="#000000"
                android:textSize="10sp"
                app:cornerRadius="20dp"
                app:strokeColor="#000000"
                app:strokeWidth="1dp" />
        </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/v_espaciador_inferior_noticias"
            android:layout_width="match_parent"
            android:layout_height="50dp" />

    </LinearLayout>
</ScrollView>